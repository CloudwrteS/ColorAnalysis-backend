{
  "info": {
    "name": "ColorAnalysis Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Collection for ColorAnalysis-backend APIs, importable to APIfox via Postman v2.1 format."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "datasetId", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "imageName", "value": "sample_001.png" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test_user\",\n  \"password\": \"123456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let jsonData = {};",
                  "try { jsonData = pm.response.json(); } catch (e) {}",
                  "if (jsonData.token) { pm.collectionVariables.set('token', jsonData.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        }
      ]
    },
    {
      "name": "Datasets",
      "item": [
        {
          "name": "Create Dataset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"dataset_demo\",\n  \"description\": \"for api test\",\n  \"ownerId\": \"admin\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/datasets"
          }
        },
        {
          "name": "List Datasets",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/datasets"
          }
        },
        {
          "name": "Get Dataset",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/datasets/{{datasetId}}"
          }
        },
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/datasets/{{datasetId}}/images/upload"
          }
        },
        {
          "name": "List Dataset Images",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/datasets/{{datasetId}}/images"
          }
        }
      ]
    },
    {
      "name": "Image Tools",
      "item": [
        {
          "name": "Canny",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "config", "type": "text", "value": "{}" }
              ]
            },
            "url": "{{baseUrl}}/api/images/canny"
          }
        },
        {
          "name": "Detect Points",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/images/correction/points"
          }
        },
        {
          "name": "Align Image",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "model", "type": "file", "src": "" },
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/images/correction/align"
          }
        },
        {
          "name": "HSV Process",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": "" },
                { "key": "mask", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/api/images/hsv/process"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"project_demo\",\n  \"ownerId\": \"admin\",\n  \"datasetId\": \"{{datasetId}}\",\n  \"templateId\": null,\n  \"config\": {}\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/projects"
          }
        },
        {
          "name": "List Projects",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/projects"
          }
        },
        {
          "name": "Get Project",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/projects/{{projectId}}"
          }
        },
        {
          "name": "Run Project",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"steps\": [\"correction\", \"hsv\", \"entropy\", \"main_color\", \"main_color_number\"],\n  \"modelImagePath\": \"D:/OperationBasepoint/ColorAnalysis-backend/color-analysis-python/model_image.jpg\",\n  \"butterflyJsonPath\": \"D:/OperationBasepoint/ColorAnalysis-backend/color-analysis-python/butterfly.json\",\n  \"edgeJsonPath\": \"D:/OperationBasepoint/ColorAnalysis-backend/color-analysis-python/edge.json\",\n  \"notes\": \"run from APIfox\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/api/projects/{{projectId}}/run"
          }
        },
        {
          "name": "List Project Tasks",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/projects/{{projectId}}/tasks"
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Project Summary",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/reports/projects/{{projectId}}/summary"
          }
        },
        {
          "name": "Single Image Report",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/reports/projects/{{projectId}}/images/{{imageName}}"
          }
        },
        {
          "name": "Export Report",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/api/reports/projects/{{projectId}}/export?format=csv"
          }
        }
      ]
    }
  ]
}
